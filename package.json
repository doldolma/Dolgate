{
  "name": "dolssh",
  "version": "1.4.3",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "overrides": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.3"
  },
  "scripts": {
    "postinstall": "patch-package",
    "dev": "npm-run-all --parallel --print-label --race dev:desktop dev:api",
    "dev:desktop": "npm run dev --workspace @dolssh/desktop",
    "dev:mobile:android": "npm run dev:android --workspace @dolssh/mobile --",
    "dev:mobile:ios": "npm run dev:ios --workspace @dolssh/mobile --",
    "build:mobile:android": "npm run build:android --workspace @dolssh/mobile --",
    "build:mobile:ios": "npm run build:ios --workspace @dolssh/mobile --",
    "version:set": "node ./scripts/version.cjs set",
    "version:check": "node ./scripts/version.cjs check",
    "version:bump:patch": "node ./scripts/version.cjs bump patch",
    "version:bump:minor": "node ./scripts/version.cjs bump minor",
    "version:bump:major": "node ./scripts/version.cjs bump major",
    "dev:api": "cd services/sync-api && go run ./cmd/api",
    "generate:icons": "node ./apps/desktop/scripts/generate-icons.cjs",
    "build": "npm run build --workspace @dolssh/desktop",
    "release:dist:mac": "npm run release:dist:mac --workspace @dolssh/desktop",
    "release:dist:win": "npm run release:dist:win --workspace @dolssh/desktop",
    "release:mac": "npm run release:publish:mac --workspace @dolssh/desktop",
    "release:win": "npm run release:publish:win --workspace @dolssh/desktop",
    "release:all": "npm run release:all --workspace @dolssh/desktop",
    "test": "npm run test:fast",
    "test:fast": "npm run test:desktop && npm run test:services",
    "test:desktop": "npm run test --workspace @dolssh/desktop",
    "test:desktop:main": "npm run test:desktop:main --workspace @dolssh/desktop",
    "test:desktop:renderer": "npm run test:desktop:renderer --workspace @dolssh/desktop",
    "test:desktop:smoke": "npm run test:desktop:smoke --workspace @dolssh/desktop",
    "test:mobile": "cd apps/mobile && jest",
    "test:ssh-core": "cd services/ssh-core && go test ./... -cover",
    "test:sync-api": "cd services/sync-api && go test ./... -cover",
    "test:services": "npm run test:ssh-core && npm run test:sync-api",
    "test:smoke": "npm run test:desktop:smoke",
    "test:all": "npm run test:fast && npm run test:smoke",
    "typecheck": "npm-run-all --parallel typecheck:desktop typecheck:mobile",
    "typecheck:desktop": "npm run typecheck --workspace @dolssh/desktop",
    "typecheck:mobile": "cd apps/mobile && tsc --noEmit"
  },
  "devDependencies": {
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-test-renderer": "19.2.3",
    "npm-run-all": "^4.1.5",
    "patch-package": "^8.0.1"
  }
}
