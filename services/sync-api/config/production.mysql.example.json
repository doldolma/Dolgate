      "enabled": true,
      "signupEnabled": true
    },
    "oidc": {
      "enabled": false,
      "displayName": "SSO",
      "issuerUrl": "",
      "clientId": "",
      "clientSecret": "",
      "redirectUrl": "https://ssh.doldolma.com/auth/oidc/callback",
      "scopes": [
        "openid",
        "profile",
        "email"
      ]
    }
  }
