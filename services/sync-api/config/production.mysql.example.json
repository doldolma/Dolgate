{
  "server": {
    "port": "8080"
  },
  "database": {
    "driver": "mysql",
    "url": "dolssh_user:CHANGE_ME_PASSWORD@tcp(mysql:3306)/dolssh?charset=utf8mb4&parseTime=True&loc=UTC"
  },
